{
  "name": "flower-dates",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "node server.js",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "prestart": "node -e \"const fs=require('fs');if(!fs.existsSync('./dist/index.html')){console.log('Сборка фронтенда...');require('child_process').execSync('npm run build',{stdio:'inherit'})}\"",
    "start": "NODE_ENV=production node server.js",
    "setup": "npm install && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2",
    "lucide-react": "^0.358.0",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  }
}
